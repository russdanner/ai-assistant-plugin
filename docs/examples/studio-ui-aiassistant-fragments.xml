<!--
  Reference fragments for config/studio/ui.xml (Studio AI assistant plugin).
  Merge each block under the parent shown in the comment. After editing, commit the site sandbox
  and sync in Studio. Re-run marketplace/copy from this plugin repo to apply descriptor-driven merges,
  or paste these fragments manually if you maintain ui.xml by hand.

  Example site sandbox (maintainer local Authoring 4.4.xE):
    /home/russdanner/crafter-installs/4-4-xE/crafter-authoring/data/repos/sites/new-demo/sandbox
  → edit: .../sandbox/config/studio/ui.xml

  Plugin bundle: id="org.craftercms.aiassistant.studio" type="aiassistant" name="components" file="index.js"
  Widget ids must match sources/src/consts.ts (Helper, AutonomousAssistants, etc.).
  Default install (craftercms-plugin.yaml): **Preview toolbar only** — Helper **appended** under PreviewToolbar **`configuration/rightSection/widgets`** (marketplace-safe wiring). **Tools Panel** (left rail) Helper / Autonomous widgets are **not** merged by the descriptor; paste the blocks below under **`ToolsPanel/configuration/widgets`** only if your policy allows. For an icon **next to the URL bar**, move the merged **`<widget id="craftercms.components.aiassistant.Helper">…</widget>`** to **`configuration/middleSection/widgets`**. One **`openAI`** vendor agent with llmModel + imageModel; **`OPENAI_API_KEY`** on Studio host.

  CRITICAL — Tools Panel placement: every sidebar tool row must live under
  //widget[@id='craftercms.components.ToolsPanel']/configuration/widgets as a <widget> child.
  Do NOT put Helper or AutonomousAssistants after </configuration> as a sibling of <configuration>;
  Studio ignores those for the left rail, and descriptor merge used to match the wrong node.
-->
<!-- ========== Tools Panel (//widget[@id='craftercms.components.ToolsPanel']/configuration/widgets) ========== -->
<widget id="craftercms.components.aiassistant.Helper">
  <plugin id="org.craftercms.aiassistant.studio" type="aiassistant" name="components" file="index.js"/>
  <configuration>
    <!-- ui="IconButton" = compact toolbar icon; omit attribute for list-style row in Tools Panel -->
    <agents>
      <!-- Primary: tools-loop chat + CMS tools (set OPENAI_API_KEY on the Studio host for the openAI vendor row). -->
      <agent>
        <crafterQAgentId>019c7237-478b-7f98-9a5c-87144c3fb010</crafterQAgentId>
        <label>Authoring Assistant</label>
        <llm>openAI</llm>
        <llmModel>gpt-4o-mini</llmModel>
        <imageModel>gpt-image-1</imageModel>
        <enableTools>true</enableTools>
        <icon id="@mui/icons-material/AutoAwesomeRounded"/>
        <prompts>
          <prompt>What can you help me with?</prompt>
          <prompt>List components used on the current page</prompt>
        </prompts>
      </agent>
      <!-- Optional second agent: hosted chat only (no GetContent/WriteContent on this adapter). Same UUID field is agentId for /v1/chats. -->
      <!--
      <agent>
        <crafterQAgentId>019c7237-478b-7f98-9a5c-87144c3fb010</crafterQAgentId>
        <label>Hosted chat only</label>
        <llm>crafterQ</llm>
        <icon id="@mui/icons-material/ChatRounded"/>
        <prompts>
          <prompt>What can you help me with?</prompt>
        </prompts>
      </agent>
      -->
    </agents>
  </configuration>
</widget>

